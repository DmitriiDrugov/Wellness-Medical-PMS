// Medical-Wellness PMS — Prisma schema
// Three data planes: OPERATIONAL, FINANCIAL (folio), COMPLIANCE/AUDIT.
// All money is stored as Int minor units (HUF x 100 = fillér). Currency lives on Property.
// Single-property runtime, multi-property seam: aggregates carry propertyId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum StaffRole {
  RECEPTION
  RESERVATION_ADMIN
  THERAPIST
  MANAGER
  HOUSEKEEPING
  ADMIN
  AI_AGENT
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum HousekeepingStatus {
  CLEAN
  DIRTY
  INSPECTED
  OUT_OF_ORDER
}

/// Lifecycle of a housekeeping work order (distinct from a room's cleanliness state).
enum HousekeepingTaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
}

enum HousekeepingTaskType {
  CLEANING
  TURNDOWN
  MAINTENANCE
  INSPECTION
  RESTOCK
  OTHER
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

/// Non-room zones of the property that can host housekeeping tasks and appear on the map.
enum AreaKind {
  COMMON
  POOL
  SPA
  RESTAURANT
  CORRIDOR
  BACK_OFFICE
  OUTDOOR
  OTHER
}

enum FolioStatus {
  OPEN
  CLOSED
}

enum LineItemType {
  ROOM
  PACKAGE
  TREATMENT
  TOURIST_TAX
  ADJUSTMENT
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum ResourceType {
  TREATMENT_ROOM
  EQUIPMENT
}

enum ComplianceEventType {
  NTAK_DAILY_REPORT
  NAV_INVOICE
}

enum ComplianceEventStatus {
  LOGGED
  SENT
  FAILED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATE_CHANGE
  LOGIN
  LOGOUT
  READ // clinical-data access logging (Phase 6)
}

// --- Phase 6: Forms & Charting (clinical) ---

enum FormType {
  INTAKE
  MEDICAL_HISTORY
  CUSTOM
}

enum SubmissionStatus {
  PENDING
  COMPLETED
}

enum ConsentType {
  TREATMENT
  GDPR_DATA_PROCESSING
  PHOTO
  MARKETING
}

enum TreatmentRecordStatus {
  DRAFT
  SIGNED
}

enum ConversationHandling {
  AI
  HUMAN
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum MessageSenderKind {
  GUEST
  AI
  STAFF
}

// ============================================================
// OPERATIONAL PLANE
// ============================================================

/// Organization / property identity. One row in the single-property MVP.
/// Holds compliance identity required by NTAK/NAV payloads.
model Property {
  id            String   @id @default(cuid())
  name          String
  legalName     String
  taxNumber     String // NAV
  ntakRegNumber String // NTAK accommodation registration number
  addressLine   String
  city          String
  postalCode    String
  country       String   @default("HU")
  timezone      String   @default("Europe/Budapest")
  currency      String   @default("HUF")
  // Hungarian tourist tax (IFA): fixed amount per taxable person per night.
  // Under-18s are exempt by default (appliesToChildren = false).
  touristTaxPerPersonPerNightMinor Int     @default(0)
  touristTaxAppliesToChildren      Boolean @default(false)
  createdAt     DateTime @default(now())

  staff             Staff[]
  roomTypes         RoomType[]
  rooms             Room[]
  areas             PropertyArea[]
  reservations      Reservation[]
  treatments        Treatment[]
  packages          ServicePackage[]
  resources         Resource[]
  appointments      TreatmentAppointment[]
  folios            Folio[]
  housekeepingTasks HousekeepingTask[]
  complianceEvents  ComplianceEvent[]
  formTemplates     FormTemplate[]
  intakeSubmissions IntakeFormSubmission[]
  consents          Consent[]
  treatmentRecords  TreatmentRecord[]
  conversations     Conversation[]
}

/// Staff member = the authenticated user. Therapist is simply role = THERAPIST.
model Staff {
  id           String    @id @default(cuid())
  propertyId   String
  property     Property  @relation(fields: [propertyId], references: [id])
  email        String    @unique
  passwordHash String
  role         StaffRole
  firstName    String
  lastName     String
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  refreshTokens         RefreshToken[]
  therapistAppointments TreatmentAppointment[] @relation("TherapistAppointments")
  housekeepingTasks     HousekeepingTask[]
  auditLogs             AuditLog[]
  providedRecords       TreatmentRecord[]      @relation("RecordProvider")
  signedRecords         TreatmentRecord[]      @relation("RecordSigner")
  assignedConversations Conversation[]         @relation("ConversationAssignee")

  @@index([propertyId])
  @@index([role])
}

/// Hashed refresh tokens — enables refresh rotation and revocation on deactivation.
/// staffId OR guestAccountId is set (token belongs to either a staff member or a guest).
model RefreshToken {
  id             String        @id @default(cuid())
  staffId        String?
  staff          Staff?        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  guestAccountId String?
  guestAccount   GuestAccount? @relation(fields: [guestAccountId], references: [id], onDelete: Cascade)
  tokenHash      String        @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime      @default(now())

  @@index([staffId])
  @@index([guestAccountId])
}

/// Portal / self-service account for a guest. One-to-one with Guest.
model GuestAccount {
  id              String    @id @default(cuid())
  guestId         String    @unique
  guest           Guest     @relation(fields: [guestId], references: [id])
  email           String    @unique
  passwordHash    String?
  inviteTokenHash String?
  invitedAt       DateTime?
  activatedAt     DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  refreshTokens RefreshToken[]
}

/// Guest profile. Org-shared in the MVP (not property-scoped). GDPR consent flags.
model Guest {
  id                       String    @id @default(cuid())
  firstName                String
  lastName                 String
  email                    String?
  phone                    String?
  nationality              String?
  dateOfBirth              DateTime?
  // Identity / travel document (deep registration).
  idDocumentType           String?   // PASSPORT | NATIONAL_ID | DRIVING_LICENCE
  idDocumentNumber         String?
  idDocumentExpiry         DateTime?
  placeOfBirth             String?
  gender                   String?
  addressLine              String?
  city                     String?
  postalCode               String?
  country                  String?
  gdprConsentDataProcessing Boolean  @default(false)
  gdprConsentMarketing     Boolean   @default(false)
  gdprConsentAt            DateTime?
  deletedAt                DateTime? // soft delete (GDPR erasure)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  reservations      Reservation[]
  appointments      TreatmentAppointment[]
  folios            Folio[]
  intakeSubmissions IntakeFormSubmission[]
  consents          Consent[]
  treatmentRecords  TreatmentRecord[]
  guestAccount      GuestAccount?
  conversation      Conversation?
  medicalProfile    MedicalProfile?
  documents         GuestDocument[]

  @@index([email])
  @@index([lastName])
}

/// Operational medical profile — at-a-glance clinical context a receptionist/therapist
/// needs to serve the guest safely (diet, allergies, contraindications, medications).
/// Distinct from the immutable clinical record (TreatmentRecord) and structured
/// intake (IntakeFormSubmission); this is the editable working summary. 1:1 with Guest.
model MedicalProfile {
  id                String   @id @default(cuid())
  guestId           String   @unique
  guest             Guest    @relation(fields: [guestId], references: [id])
  dietaryNotes      String?
  allergies         String?
  contraindications String?
  currentMedications String?
  prescriptions     String?
  mobilityNotes     String?
  generalNotes      String?
  updatedByStaffId  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// Reference to an external guest document (passport scan, medical report, consent
/// PDF). No blobs are stored — `externalRef` is an opaque key/URL, mirroring the
/// docRef/photoRefs pattern used elsewhere.
model GuestDocument {
  id               String   @id @default(cuid())
  guestId          String
  guest            Guest    @relation(fields: [guestId], references: [id])
  kind             String   // PASSPORT | MEDICAL_REPORT | PRESCRIPTION | CONSENT | OTHER
  label            String
  externalRef      String
  uploadedByStaffId String?
  createdAt        DateTime @default(now())

  @@index([guestId])
}

model RoomType {
  id            String   @id @default(cuid())
  propertyId    String
  property      Property @relation(fields: [propertyId], references: [id])
  name          String
  description   String?
  basePriceMinor Int // per night, minor units
  maxOccupancy  Int      @default(2)

  rooms        Room[]
  reservations Reservation[]

  @@unique([propertyId, name])
  @@index([propertyId])
}

model Room {
  id                 String             @id @default(cuid())
  propertyId         String
  property           Property           @relation(fields: [propertyId], references: [id])
  number             String
  roomTypeId         String
  roomType           RoomType           @relation(fields: [roomTypeId], references: [id])
  floor              Int?
  housekeepingStatus HousekeepingStatus @default(DIRTY)
  // Floor-plan placement (grid cells). Null until the room is dragged onto the map.
  posX               Int?
  posY               Int?
  width              Int                @default(2)
  height             Int                @default(2)
  createdAt          DateTime           @default(now())

  reservations     Reservation[]
  housekeepingTasks HousekeepingTask[]

  @@unique([propertyId, number])
  @@index([propertyId])
  @@index([roomTypeId])
}

model Reservation {
  id               String            @id @default(cuid())
  propertyId       String
  property         Property          @relation(fields: [propertyId], references: [id])
  guestId          String
  guest            Guest             @relation(fields: [guestId], references: [id])
  roomTypeId       String
  roomType         RoomType          @relation(fields: [roomTypeId], references: [id])
  roomId           String? // allocated room (nullable until assigned)
  room             Room?             @relation(fields: [roomId], references: [id])
  checkInDate      DateTime
  checkOutDate     DateTime
  status           ReservationStatus @default(PENDING)
  adults           Int               @default(1)
  children         Int               @default(0)
  ratePerNightMinor Int
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  folio        Folio?
  appointments TreatmentAppointment[]

  @@index([propertyId])
  @@index([guestId])
  @@index([roomId, checkInDate, checkOutDate])
  @@index([status])
}

model Treatment {
  id                  String       @id @default(cuid())
  propertyId          String
  property            Property     @relation(fields: [propertyId], references: [id])
  name                String
  description         String?
  durationMinutes     Int
  priceMinor          Int
  requiredResourceType ResourceType
  active              Boolean      @default(true)

  appointments TreatmentAppointment[]
  packageItems PackageItem[]

  @@index([propertyId])
}

model ServicePackage {
  id          String        @id @default(cuid())
  propertyId  String
  property    Property      @relation(fields: [propertyId], references: [id])
  name        String
  description String?
  priceMinor  Int
  active      Boolean       @default(true)

  items PackageItem[]

  @@index([propertyId])
}

model PackageItem {
  id          String         @id @default(cuid())
  packageId   String
  package     ServicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  treatmentId String
  treatment   Treatment      @relation(fields: [treatmentId], references: [id])
  quantity    Int            @default(1)

  @@unique([packageId, treatmentId])
  @@index([packageId])
}

model Resource {
  id         String       @id @default(cuid())
  propertyId String
  property   Property     @relation(fields: [propertyId], references: [id])
  name       String
  type       ResourceType
  capacity   Int          @default(1)
  active     Boolean      @default(true)

  appointments TreatmentAppointment[]

  @@index([propertyId])
  @@index([type])
}

model TreatmentAppointment {
  id            String            @id @default(cuid())
  propertyId    String
  property      Property          @relation(fields: [propertyId], references: [id])
  guestId       String
  guest         Guest             @relation(fields: [guestId], references: [id])
  treatmentId   String
  treatment     Treatment         @relation(fields: [treatmentId], references: [id])
  therapistId   String
  therapist     Staff             @relation("TherapistAppointments", fields: [therapistId], references: [id])
  resourceId    String
  resource      Resource          @relation(fields: [resourceId], references: [id])
  startTime     DateTime
  endTime       DateTime
  status        AppointmentStatus @default(SCHEDULED)
  reservationId String?
  reservation   Reservation?      @relation(fields: [reservationId], references: [id])
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  treatmentRecords TreatmentRecord[]

  @@index([propertyId])
  @@index([guestId])
  @@index([therapistId, startTime, endTime])
  @@index([resourceId, startTime, endTime])
  @@index([status])
}

// ============================================================
// FINANCIAL PLANE
// ============================================================

model Folio {
  id            String      @id @default(cuid())
  propertyId    String
  property      Property    @relation(fields: [propertyId], references: [id])
  guestId       String
  guest         Guest       @relation(fields: [guestId], references: [id])
  reservationId String?     @unique
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
  status        FolioStatus @default(OPEN)
  openedAt      DateTime    @default(now())
  closedAt      DateTime?

  lineItems FolioLineItem[]
  payments  Payment[]

  @@index([propertyId])
  @@index([guestId])
}

model FolioLineItem {
  id              String       @id @default(cuid())
  folioId         String
  folio           Folio        @relation(fields: [folioId], references: [id], onDelete: Cascade)
  type            LineItemType
  description     String
  quantity        Int          @default(1)
  unitPriceMinor  Int
  amountMinor     Int // quantity * unitPriceMinor (stored for ledger immutability)
  sourceType      String? // e.g. "Reservation", "TreatmentAppointment", "ServicePackage"
  sourceId        String?
  createdByStaffId String?
  createdAt       DateTime     @default(now())

  @@index([folioId])
}

model Payment {
  id               String        @id @default(cuid())
  folioId          String
  folio            Folio         @relation(fields: [folioId], references: [id], onDelete: Cascade)
  amountMinor      Int
  method           PaymentMethod
  reference        String?
  recordedByStaffId String?
  paidAt           DateTime      @default(now())

  @@index([folioId])
}

// ============================================================
// HOUSEKEEPING (operational, but its own lifecycle)
// ============================================================

/// A non-room zone of the property (lobby, pool, spa, corridor). A housekeeping
/// task can target an Area instead of a Room. Also rendered on the property map.
model PropertyArea {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  name       String
  kind       AreaKind @default(COMMON)
  floor      Int?
  posX       Int?
  posY       Int?
  width      Int      @default(3)
  height     Int      @default(2)
  notes      String?
  createdAt  DateTime @default(now())

  housekeepingTasks HousekeepingTask[]

  @@index([propertyId])
}

/// A housekeeping work order. Targets a Room OR a PropertyArea (both optional so a
/// task can be a general property job). Its `status` is a work-order lifecycle,
/// separate from a Room's `housekeepingStatus` cleanliness flag.
model HousekeepingTask {
  id                String                 @id @default(cuid())
  propertyId        String
  property          Property               @relation(fields: [propertyId], references: [id])
  roomId            String?
  room              Room?                  @relation(fields: [roomId], references: [id])
  areaId            String?
  area              PropertyArea?          @relation(fields: [areaId], references: [id])
  type              HousekeepingTaskType   @default(CLEANING)
  status            HousekeepingTaskStatus @default(OPEN)
  priority          TaskPriority           @default(NORMAL)
  title             String
  notes             String?
  assignedToStaffId String?
  assignedTo        Staff?                 @relation(fields: [assignedToStaffId], references: [id])
  createdByStaffId  String?
  createdAt         DateTime               @default(now())
  startedAt         DateTime?
  completedAt       DateTime?

  @@index([propertyId, status])
  @@index([assignedToStaffId, status])
  @@index([roomId])
  @@index([areaId])
}

// ============================================================
// COMPLIANCE / AUDIT PLANE
// ============================================================

/// APPEND-ONLY. The repository exposes only create(); never update/delete.
/// Production hardening: a Postgres rule/trigger or REVOKE UPDATE,DELETE (see ADR 0002).
model AuditLog {
  id           String      @id @default(cuid())
  propertyId   String?
  actorStaffId String?
  actor        Staff?      @relation(fields: [actorStaffId], references: [id])
  action       AuditAction
  entityType   String
  entityId     String
  before       Json?
  after        Json?
  metadata     Json?
  createdAt    DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([actorStaffId])
  @@index([createdAt])
}

/// Logged NTAK/NAV payloads the system WOULD send (gateway is stubbed in the MVP).
model ComplianceEvent {
  id                String                @id @default(cuid())
  propertyId        String
  property          Property              @relation(fields: [propertyId], references: [id])
  type              ComplianceEventType
  payload           Json
  status            ComplianceEventStatus @default(LOGGED)
  relatedEntityType String?
  relatedEntityId   String?
  createdAt         DateTime              @default(now())

  @@index([propertyId])
  @@index([type])
}

// ============================================================
// CLINICAL PLANE (Phase 6 — health-adjacent data; strict RBAC + consent gate)
// ============================================================

/// Definition of an intake / medical-history / custom form. Editing bumps `version`.
model FormTemplate {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  name       String
  type       FormType
  schema     Json // question definitions
  version    Int      @default(1)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  submissions IntakeFormSubmission[]

  @@unique([propertyId, name])
  @@index([propertyId])
}

/// A guest's answers to a form template. `templateVersion` is captured so answers
/// remain interpretable even if the template is later edited.
model IntakeFormSubmission {
  id              String           @id @default(cuid())
  propertyId      String
  property        Property         @relation(fields: [propertyId], references: [id])
  guestId         String
  guest           Guest            @relation(fields: [guestId], references: [id])
  templateId      String
  template        FormTemplate     @relation(fields: [templateId], references: [id])
  templateVersion Int
  answers         Json
  status          SubmissionStatus @default(PENDING)
  submittedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([propertyId])
  @@index([guestId])
}

/// History-preserving consent. Revoke sets `revokedAt`; a new grant is a new row.
/// Never hard-deleted. Current consent of a type = latest row with revokedAt = null.
model Consent {
  id         String      @id @default(cuid())
  propertyId String
  property   Property    @relation(fields: [propertyId], references: [id])
  guestId    String
  guest      Guest       @relation(fields: [guestId], references: [id])
  type       ConsentType
  version    String // policy/text version
  text       String? // inline consent text
  docRef     String? // opaque external document reference (no blobs stored)
  grantedAt  DateTime    @default(now())
  revokedAt  DateTime?
  createdAt  DateTime    @default(now())

  @@index([guestId, type])
  @@index([propertyId])
}

/// Clinical SOAP record for a treatment. IMMUTABLE once SIGNED — corrections create
/// an addendum (a new record whose `supersededById` points to the prior record).
/// The signed original is never mutated. `aiGenerated` is set by the Phase 9 scribe.
model TreatmentRecord {
  id                     String                @id @default(cuid())
  propertyId             String
  property               Property              @relation(fields: [propertyId], references: [id])
  treatmentAppointmentId String
  appointment            TreatmentAppointment  @relation(fields: [treatmentAppointmentId], references: [id])
  guestId                String
  guest                  Guest                 @relation(fields: [guestId], references: [id])
  providerId             String
  provider               Staff                 @relation("RecordProvider", fields: [providerId], references: [id])
  subjective             String?
  objective              String?
  assessment             String?
  plan                   String?
  productsUsed           Json?
  photoRefs              Json? // array of opaque external keys
  status                 TreatmentRecordStatus @default(DRAFT)
  aiGenerated            Boolean               @default(false)
  signedById             String?
  signedBy               Staff?                @relation("RecordSigner", fields: [signedById], references: [id])
  signedAt               DateTime?
  supersededById         String?               @unique // set on an addendum -> the prior record it supersedes
  supersedes             TreatmentRecord?      @relation("RecordSupersession", fields: [supersededById], references: [id])
  supersededByRecord     TreatmentRecord?      @relation("RecordSupersession")
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@index([propertyId])
  @@index([guestId])
  @@index([treatmentAppointmentId])
}

// ============================================================
// MESSAGING PLANE (Phase 7 — AI receptionist + guest portal)
// ============================================================

/// One conversation per guest per property (unique on guestId).
model Conversation {
  id              String               @id @default(cuid())
  propertyId      String
  property        Property             @relation(fields: [propertyId], references: [id])
  guestId         String               @unique
  guest           Guest                @relation(fields: [guestId], references: [id])
  handling        ConversationHandling @default(AI)
  status          ConversationStatus   @default(OPEN)
  assignedStaffId String?
  assignedStaff   Staff?               @relation("ConversationAssignee", fields: [assignedStaffId], references: [id])
  lastMessageAt   DateTime             @default(now())
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  messages Message[]

  @@index([propertyId, status])
  @@index([propertyId, handling])
}

model Message {
  id             String            @id @default(cuid())
  conversationId String
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderKind     MessageSenderKind
  senderStaffId  String?
  body           String
  actionType     String?
  actionId       String?
  createdAt      DateTime          @default(now())

  @@index([conversationId, createdAt])
}
