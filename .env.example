# --- Database (hosted Postgres: Neon/Supabase) ---
# Pooled connection used by the app at runtime (e.g. Neon pooler / pgbouncer).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"
# Direct (non-pooled) connection used by Prisma Migrate.
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth ---
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
ACCESS_TOKEN_TTL="900"          # seconds (15 min)
REFRESH_TOKEN_TTL="2592000"     # seconds (30 days)

# --- Current property (single-property MVP; see multi-property seam in the spec) ---
# Leave unset to use the seeded default property resolved by config.ts.
PROPERTY_ID=""
