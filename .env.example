# --- Database (Supabase Postgres) ---
# Supabase exposes THREE connection modes. The direct host (db.<ref>.supabase.co)
# is IPv6-only and is NOT reachable from Vercel or most IPv4 networks — use the
# pooler hosts below. Grab both from the Supabase dashboard: "Connect" button.
#
# DATABASE_URL  = Transaction pooler (port 6543) — app runtime / serverless.
# DIRECT_URL    = Session pooler   (port 5432) — Prisma Migrate.
# Percent-encode special chars in the password (e.g. "!" -> "%21").
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
ACCESS_TOKEN_TTL="900"          # seconds (15 min)
REFRESH_TOKEN_TTL="2592000"     # seconds (30 days)

# --- Current property (single-property MVP; see multi-property seam in the spec) ---
# Leave unset to use the seeded default property resolved by config.ts.
PROPERTY_ID=""
